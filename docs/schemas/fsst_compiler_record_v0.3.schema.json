{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://formal-symbolic-systems-theory.local/schemas/fsst_compiler_record_v0.3.schema.json",
  "title": "FSST Compact Compiler Record v0.3",
  "allOf": [
    { "$ref": "fsst_compiler_record.schema.json" },
    {
      "type": "object",
      "required": ["validation", "review"],
      "properties": {
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["record_validation_status", "validated_by", "validated_at", "schema_version"],
          "properties": {
            "record_validation_status": {
              "type": "string",
              "enum": ["not_validated", "passed", "failed", "warnings"]
            },
            "validated_by": { "type": "string" },
            "validated_at": { "type": "string" },
            "schema_version": {
              "type": "string",
              "enum": ["fsst_compiler_record_v0.3", "fsst_compiler_record_v0.4"]
            }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cold_review_status", "promotion_authority", "operator_instruction_reference"],
          "properties": {
            "cold_review_status": {
              "type": "string",
              "enum": ["not_required", "absent", "pending", "passed", "failed", "waived"]
            },
            "promotion_authority": { "type": "string" },
            "operator_instruction_reference": { "type": "string" }
          }
        },
        "scope": {
          "type": "object",
          "properties": {
            "scope_conditions": { "type": "string", "minLength": 1 },
            "prohibited_scope_extensions": {
              "type": "array",
              "minItems": 1
            }
          }
        },
        "recognition_authority": {
          "type": "object",
          "required": [
            "distributed_standing",
            "standing_resolution_state",
            "standing_resolution_basis",
            "standing_open_questions"
          ],
          "properties": {
            "standing_resolution_state": {
              "type": "string",
              "enum": ["resolved", "partially_resolved", "unresolved", "contested", "not_applicable"]
            },
            "standing_resolution_basis": { "type": "string", "minLength": 1 },
            "standing_open_questions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "distributed_standing": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "recognizer",
                  "standing_scope",
                  "standing_basis",
                  "standing_resolution_state",
                  "standing_resolution_basis",
                  "standing_resolution_blockers",
                  "licensed_consequences",
                  "blocked_consequences"
                ],
                "properties": {
                  "standing_resolution_state": {
                    "type": "string",
                    "enum": ["established", "restricted", "unresolved", "contested", "out_of_scope"]
                  },
                  "standing_resolution_basis": { "type": "string", "minLength": 1 },
                  "standing_resolution_blockers": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "licensed_consequences": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "blocked_consequences": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "policy_license": {
          "type": "object",
          "required": ["all_or_refuse_policy"],
          "properties": {
            "all_or_refuse_policy": { "type": "boolean" },
            "blocked_consequences": {
              "type": "array",
              "minItems": 1
            },
            "consequence_routes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["consequence", "route_status", "recognizer_chain", "route_basis"],
                "properties": {
                  "consequence": { "type": "string", "minLength": 1 },
                  "route_status": {
                    "type": "string",
                    "enum": ["licensed", "licensed_with_restriction", "blocked", "deferred", "unlicensed"]
                  },
                  "recognizer_chain": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string" }
                  },
                  "route_basis": { "type": "string", "minLength": 1 },
                  "blocked_by": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
