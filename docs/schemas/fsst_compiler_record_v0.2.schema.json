{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://formal-symbolic-systems-theory.local/schemas/fsst_compiler_record_v0.2.schema.json",
  "title": "FSST Compact Compiler Record v0.2",
  "allOf": [
    { "$ref": "fsst_compiler_record.schema.json" },
    {
      "type": "object",
      "required": ["validation", "review"],
      "properties": {
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["record_validation_status", "validated_by", "validated_at", "schema_version"],
          "properties": {
            "record_validation_status": {
              "type": "string",
              "enum": ["not_validated", "passed", "failed", "warnings"]
            },
            "validated_by": { "type": "string" },
            "validated_at": { "type": "string" },
            "schema_version": { "type": "string", "const": "fsst_compiler_record_v0.2" }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cold_review_status", "promotion_authority", "operator_instruction_reference"],
          "properties": {
            "cold_review_status": {
              "type": "string",
              "enum": ["not_required", "absent", "pending", "passed", "failed", "waived"]
            },
            "promotion_authority": { "type": "string" },
            "operator_instruction_reference": { "type": "string" }
          }
        },
        "scope": {
          "type": "object",
          "properties": {
            "scope_conditions": { "type": "string", "minLength": 1 },
            "prohibited_scope_extensions": {
              "type": "array",
              "minItems": 1
            }
          }
        },
        "recognition_authority": {
          "type": "object",
          "required": ["distributed_standing"],
          "properties": {
            "distributed_standing": {
              "type": "array",
              "minItems": 1
            }
          }
        },
        "policy_license": {
          "type": "object",
          "required": ["all_or_refuse_policy"],
          "properties": {
            "all_or_refuse_policy": { "type": "boolean" },
            "blocked_consequences": {
              "type": "array",
              "minItems": 1
            }
          }
        }
      }
    }
  ]
}
